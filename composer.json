{
    "name": "tpl-best-tinapa/cms",
    "description": "PTL Best Tinapa e-commerce CMS",
    "type": "project",
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpstan analyse",
        "ci": [
            "@lint",
            "@test"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
